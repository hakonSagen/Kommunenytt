OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# Municipal sources used by this MVP.
INDRE_FOSEN_URL=https://www.indrefosen.kommune.no/tjenester/politikk-planer-og-okonomi/politikk/moteoversikt-og-sok-etter-vedtak/
OSEN_URL=https://www.osen.kommune.no/vare-tjenester/politikk-planer-og-organisasjon/politikk/politiske-moter-og-saksdokumenter/
AFJORD_URL=https://www.afjord.kommune.no/tjenester/politikk-planer-og-organisasjon/politikk-og-okonomi/politisk-moteplan-og-saksdokumenter/
ORLAND_URL=https://www.orland.kommune.no/vare-tjenester/politikk-planer-og-organisasjon/politikk/politisk-moteplan/

# Optional PostgreSQL. If empty, the app uses local SQLite in data/processed/.
DATABASE_URL=

# SMTP. Keep DRY_RUN_EMAIL=true while testing.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=fosnafolketskrapebot@gmail.com
SMTP_TO=hakon.sagen@fosna-folket.no
SMTP_USE_TLS=true
DRY_RUN_EMAIL=true
